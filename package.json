{
  "name": "@divyaunagar/react-native-pinch-viewer",
  "version": "1.0.0",
  "description": "A highly customizable React Native pinch-to-zoom viewer built with gesture-handler and reanimated, providing smooth zooming, panning, and high-performance animations for images.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "react-native": "src/index.tsx",
  "source": "src/index.tsx",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "import": "./lib/module/index.js",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-pinch-viewer-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "release": "release-it",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "image",
    "viewer",
    "gallery",
    "pinch",
    "zoom",
    "reanimated",
    "gesture-handler",
    "expo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DivyaUnagar/react-native-pinch-viewer.git"
  },
  "author": "Divya Unagar <divyaungar610@gmail.com> (https://github.com/DivyaUnagar)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DivyaUnagar/react-native-pinch-viewer/issues"
  },
  "homepage": "https://github.com/DivyaUnagar/react-native-pinch-viewer#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.83.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.12",
    "del-cli": "^6.0.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.40.13",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-worklets": "^0.8.1",
    "release-it": "^19.0.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": ">= 2.0.0",
    "react-native-reanimated": ">= 3.0.0"
  },
  "workspaces": [
    "react-native-pinch-viewer-example"
  ],
  "resolutions": {
    "onetime": "5.1.2",
    "signal-exit": "3.0.7"
  },
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "release-it",
      "jest"
    ],
    "version": "0.57.2"
  }
}
