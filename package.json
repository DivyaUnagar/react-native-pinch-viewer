{
  "name": "react-native-pinch-viewer",
  "version": "1.0.2",
  "description": "A high-performance, smooth React Native pinch-to-zoom image viewer and gallery. Built with Reanimated 3 and Gesture Handler for 60fps animations. Supports pinch-to-zoom, panning, swipe-to-close, and thumbnails.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "react-native": "src/index.tsx",
  "source": "src/index.tsx",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "import": "./lib/module/index.js",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-pinch-viewer-example",
    "build": "bob build",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "release": "release-it",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "image-viewer",
    "pinch-to-zoom",
    "gallery",
    "reanimated",
    "gesture-handler",
    "expo",
    "ios",
    "android",
    "lightbox",
    "carousel",
    "photo-viewer",
    "image-zoom"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DivyaUnagar/react-native-pinch-viewer.git"
  },
  "author": "Divya Unagar <divyaungar610@gmail.com> (https://github.com/DivyaUnagar)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DivyaUnagar/react-native-pinch-viewer/issues"
  },
  "homepage": "https://github.com/DivyaUnagar/react-native-pinch-viewer#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "^0.84.1",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.12",
    "@types/react-test-renderer": "^19.1.0",
    "del-cli": "^6.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.40.13",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-worklets": "^0.8.1",
    "react-test-renderer": "^19.2.4",
    "release-it": "^19.0.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">= 0.71.0",
    "react-native-gesture-handler": ">= 2.10.0",
    "react-native-reanimated": ">= 3.3.0"
  },
  "workspaces": [
    "react-native-pinch-viewer-example"
  ],
  "resolutions": {
    "onetime": "5.1.2",
    "signal-exit": "3.0.7"
  },
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNCPinchViewerSpec",
    "type": "all",
    "jsSrcsDir": "src"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/react-native-pinch-viewer-example/node_modules",
      "<rootDir>/lib/"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/test.js",
      "<rootDir>/react-native-pinch-viewer-example/test.js",
      "<rootDir>/react-native-pinch-viewer-example/test_gesture.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-reanimated|react-native-gesture-handler|react-native-worklets)/)"
    ],
    "transform": {
      "^.+\\.(js|ts|tsx)$": "babel-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "release-it",
      "jest"
    ],
    "version": "0.57.2"
  }
}
